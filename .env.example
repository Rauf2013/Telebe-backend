# ============================================================
# EduGate — Backend Environment Variables
# ------------------------------------------------------------
# 1) Bu faylı `.env` adı ilə kopyalayın
# 2) Aşağıdakı dəyərləri öz dəyərlərinizlə əvəz edin
# 3) Backend yenidən başladın (npm run dev)
# ============================================================

# --- Server ---
PORT=4000
JWT_SECRET=cox-uzun-rastgele-string-buraya-yazin-en-az-32-karakter

# --- İlk Moderator (yalnız ilk başlatmada işləyir) ---
ADMIN_EMAIL=admin@edugate.local
ADMIN_PASSWORD=admin123
ADMIN_NAME=System Administrator

# --- Frontend URL (CORS + email linkləri üçün) ---
FRONTEND_URL=http://localhost:5173

# ============================================================
# GMAIL SMTP — Gerçek mail göndərmək üçün
# ============================================================
# Gmail SMTP istifadə etmək üçün aşağıdakı addımları izləyin:
#
# 1. Gmail hesabınızda 2-Step Verification açın
#    https://myaccount.google.com/security
#
# 2. App Password yaradın (Gmail SMTP üçün xüsusi şifrə)
#    https://myaccount.google.com/apppasswords
#    - Select app: "Mail"
#    - Select device: "Other" → "EduGate"
#    - 16 karakterli şifrə alacaqsınız (boşluqları silmədən kopyalayın)
#
# 3. Aşağıdakı dəyərləri doldurun və backendi yenidən başladın
# ------------------------------------------------------------

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=sizin.email@gmail.com
SMTP_PASS=abcd efgh ijkl mnop
MAIL_FROM="EduGate <sizin.email@gmail.com>"

# ============================================================
# Qeyd: Əgər SMTP_HOST boşdursa, sistem Ethereal (test SMTP) istifadə edir
# Bu vəziyyətdə mail real olaraq göndərilmir, sadəcə preview link verilir.
# Production üçün mütləq Gmail/SendGrid/Mailgun kimi gerçək SMTP konfiq edin.
